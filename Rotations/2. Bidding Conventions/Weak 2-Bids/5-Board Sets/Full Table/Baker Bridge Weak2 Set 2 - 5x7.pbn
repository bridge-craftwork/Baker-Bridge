[Site ""]
[Date ""]
[Board "1"]
[Dealer "N"]
[Vulnerable "None"]
[Deal "N:KQ9763.T2.K62.74 T2.KQ965.T97.KJ6 A854.73.J85.QT83 J.AJ84.AQ43.A952"]
[Declarer "N"]
[Contract "4S"]
[Result ""]
[Auction "N"]
2S pass 4S pass pass pass
[BCFlags "1f"]
[RotationNote "Board 1, chOption: N, chBasis: N, basisKind:Declarer, nOption:0, nBasis: 0, nRot: 0, useStandardVul: true"]
