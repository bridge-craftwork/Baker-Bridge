[Dealer "S"]
[Vulnerable "EW"]
[Deal "S:KQ3.A54.A94.K832 AJ97.J73.KQ5.QJ4 T8652.T.JT72.A96 4.KQ9862.863.T75"]
[Declarer "E"]
