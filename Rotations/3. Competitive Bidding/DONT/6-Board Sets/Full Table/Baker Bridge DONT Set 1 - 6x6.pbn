[Board "1"]
[Dealer "E"]
[Vulnerable "None"]
[Deal "E:KJ6.A53.K54.AT92 54.KQ982.AJT96.3 QT87.74.Q82.J874 A932.JT6.73.KQ65"]
[Declarer "N"]
