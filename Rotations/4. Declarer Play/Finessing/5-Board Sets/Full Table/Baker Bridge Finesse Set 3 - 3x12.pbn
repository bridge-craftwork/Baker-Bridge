[Result ""]
[Auction "N"]
2C pass 2D pass 2S pass 2NT pass 4S pass pass pass
[BCFlags "1f"]
[RotationNote "Board 1, chOption: N, chBasis: S, basisKind:Declarer, nOption:0, nBasis: 2, nRot: 2, useStandardVul: true"]
[BoardVersionToken "56a32c802851317deb6514f714404b805b3968865da5ac8a1c784355c85ff54a"]
