[Contract "6NT"]
[Result ""]
[Auction "S"]
1C pass 2D pass 2S pass 4NT pass 5H pass 6NT pass pass pass
[BCFlags "1f"]
[RotationNote "Board 1, chOption: N, chBasis: S, basisKind:Declarer, nOption:0, nBasis: 2, nRot: 2, useStandardVul: true"]
[BoardVersionToken "ed7d41feaebf85081bb75504454fe418c1f01adf6866157c6bd94eb7c2dc2b85"]
