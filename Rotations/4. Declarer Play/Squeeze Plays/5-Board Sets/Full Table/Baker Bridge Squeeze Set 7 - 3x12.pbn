[Deal "E:A.A63.K5.AKQJ987 KQ963.Q985.9.T62 J8.K74.AJ8762.53 T7542.JT2.QT43.4"]
[Declarer "E"]
[Contract "7C"]
[Result ""]
[Auction "E"]
2C pass 3D pass 4NT pass 5D pass 5NT pass 6D pass 7C pass pass pass
[BCFlags "1f"]
[RotationNote "Board 3, chOption: E, chBasis: S, basisKind:Declarer, nOption:1, nBasis: 2, nRot: 3, useStandardVul: true"]
[BoardVersionToken "e71b40e5c33b4458280cdcea1ab5e9128301b3fcad20ab11e93677741e91eadc"]
[Category "Declarer Play"]
