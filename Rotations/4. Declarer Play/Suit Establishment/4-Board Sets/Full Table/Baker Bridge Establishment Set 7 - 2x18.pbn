[Dealer "S"]
[Vulnerable "None"]
[Deal "S:83.75.AQT62.AK74 J97.QT96.J9.JT62 AK52.AK43.753.95 QT64.J82.K84.Q83"]
[Declarer "N"]
[Contract "3NT"]
[Result ""]
[Auction "S"]
1D pass 1H pass 2C pass 3NT pass pass pass
[BCFlags "1f"]
[RotationNote "Board 1, chOption: N, chBasis: S, basisKind:Declarer, nOption:0, nBasis: 2, nRot: 2, useStandardVul: true"]
[BoardVersionToken "d500d2baba6183bff18470738f535f01864d0066fe7332fd8f85ab6347cf1739"]
[Category "Declarer Play"]
