[Dealer "E"]
[Vulnerable "EW"]
[Deal "E:85.QJT9742.5.KJ8 KQJT743.5.Q3.Q75 A962.A8.A876.A43 .K63.KJT942.T962"]
[Declarer "E"]
[Contract "4H"]
