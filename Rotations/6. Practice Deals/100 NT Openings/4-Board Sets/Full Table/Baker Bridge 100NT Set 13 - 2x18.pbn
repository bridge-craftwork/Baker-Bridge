[Result ""]
[Auction "E"]
1NT pass 2D pass 2H pass 4H pass pass pass
[BCFlags "1f"]
[RotationNote "Board 3, chOption: E, chBasis: S, basisKind:Declarer, nOption:1, nBasis: 2, nRot: 3, useStandardVul: true"]
[BoardVersionToken "e62eab42a22c3073da332ffdff85a848312dfe7113b934fe6236266a9cea39c7"]
[Category "Practice Deals"]
