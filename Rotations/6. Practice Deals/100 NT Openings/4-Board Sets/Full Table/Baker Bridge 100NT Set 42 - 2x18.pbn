[Deal "N:QJ94.A53.A8.A863 K73.K92.T74.KQJ4 T862.T874.Q653.7 A5.QJ6.KJ92.T952"]
[Declarer "N"]
[Contract "2S"]
[Result ""]
[Auction "N"]
1NT pass 2C pass 2S pass pass pass
[BCFlags "1f"]
[RotationNote "Board 1, chOption: N, chBasis: S, basisKind:Declarer, nOption:0, nBasis: 2, nRot: 2, useStandardVul: true"]
[BoardVersionToken "dfd8f33f47ff8b8def7bb288202d445e8d09e9ad0172210a7582920487f6cbf0"]
