[Deal "W:95.KQ7.KQ73.AJ96 QT64.A4.AT2.8432 AK732.JT986.64.5 J8.532.J985.KQT7"]
[Declarer "E"]
[Contract "4H"]
[Result ""]
[Auction "W"]
1NT pass 2H pass 2S pass 3H pass 4H pass pass pass
[BCFlags "1f"]
[RotationNote "Board 3, chOption: E, chBasis: S, basisKind:Declarer, nOption:1, nBasis: 2, nRot: 3, useStandardVul: true"]
[BoardVersionToken "75b1a4e4c6fcaff843c0f5d03c7b598d264a35e59f9a1ae59d0b61916f6b3722"]
[Category "Practice Deals"]
