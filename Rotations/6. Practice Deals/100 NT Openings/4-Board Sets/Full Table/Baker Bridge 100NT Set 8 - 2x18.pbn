[Deal "N:KQJ8.KQ.A65.J763 953.JT86.Q972.94 A6.972.KT83.AKQ5 T742.A543.J4.T82"]
[Declarer "N"]
[Contract "6NT"]
[Result ""]
[Auction "N"]
1NT pass 4NT pass 6NT pass pass pass
[BCFlags "1f"]
[RotationNote "Board 1, chOption: N, chBasis: S, basisKind:Declarer, nOption:0, nBasis: 2, nRot: 2, useStandardVul: true"]
