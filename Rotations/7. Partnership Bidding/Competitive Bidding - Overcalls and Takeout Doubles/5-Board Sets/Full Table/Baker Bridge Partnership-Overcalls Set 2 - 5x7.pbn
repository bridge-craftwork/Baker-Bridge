[Dealer "S"]
[Vulnerable "All"]
[Deal "S:KQ9.T95.KQT.A932 A86.KQJ.AJ97.KQ4 743.A83.5432.T75 JT52.7642.86.J86"]
[Declarer "W"]
[Contract "1NT"]
